{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PVN v2",
  "version": "0.1.0",
  "identifier": "com.pvn.v2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PVN v2",
        "width": 480,
        "height": 680,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "resources": [
      "resources/pvn-v2-service.exe",
      "resources/install-helper-service.ps1",
      "resources/uninstall-helper-service.ps1"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "./windows/nsis-hooks.nsh"
      }
    }
  }
}
